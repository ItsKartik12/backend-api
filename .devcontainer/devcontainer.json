{
  "name": "Node.js & MERN Backend",
  // Uses the stable, official long-term support image for Node 20 or 22
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "features": {
    // Keeps your shell configurations cleaner if needed, otherwise this can be empty
    "ghcr.io/devcontainer-config/features/dot-config:4": {}
  },

  // Automatically forwards your Express/Node port (e.g., 5000 or 8000) when the server runs
  "forwardPorts": [5000],

  // Automatically runs npm install once the container is built so you don't have to
  "postCreateCommand": "npm install",

  // Customizes VS Code settings inside the Codespace container
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
    }
  },

  "remoteUser": "node"
}
