{
  "compilerOptions": {
    "target": "ES2022",       // Or your preferred target
    "module": "commonjs",     // Or your preferred module system
    "skipLibCheck": true,     // <-- CRITICAL: Skips type checking of declaration files
    "strict": true
  },
  "exclude": [
    "node_modules"            // <-- CRITICAL: Prevents TS from scanning this folder
  ]
}